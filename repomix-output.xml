# src/ssunet/modules/normalization.py
"""Normalization layers for 3D convolution outputs."""

import torch
from torch import nn


class LayerNorm3D(nn.Module):
    """LayerNorm for 3D convolution outputs."""

    def __init__(self, num_features: int, eps: float = 1e-5):
        super().__init__()
        # LayerNorm default elementwise_affine=True, meaning it has learnable gamma and beta
        self.norm = nn.LayerNorm(num_features, eps=eps)

    def forward(self, x: torch.Tensor) -> torch.Tensor:  # x is (B, C, D, H, W)
        x = x.permute(0, 2, 3, 4, 1)  # (B, D, H, W, C)
        x = self.norm(x)
        return x.permute(0, 4, 1, 2, 3)  # (B, C, D, H, W)


def get_norm_layer(norm_type: str, num_features: int, **kwargs: dict) -> nn.Module:
    """Factory function to get normalization layer."""
    norm_type_lower = norm_type.lower()
    if num_features <= 0:  # Cannot normalize 0 features
        return nn.Identity()

    if norm_type_lower == "layer":
        return LayerNorm3D(num_features, **kwargs)  # eps can be passed via kwargs
    if norm_type_lower == "batch":
        # BatchNorm3d default affine=True (learnable gamma/beta)
        return nn.BatchNorm3d(num_features, **kwargs)  # eps, momentum etc.
    if norm_type_lower == "group":
        num_groups = kwargs.get("num_groups", 32)
        if num_features % num_groups != 0:
            # Try to find a valid number of groups
            found_valid_group = False
            for ng in range(min(num_groups, num_features), 0, -1):
                if num_features % ng == 0:
                    num_groups = ng
                    found_valid_group = True
                    break
            if not found_valid_group:  # Should not happen if num_features > 0
                num_groups = 1  # Fallback to LayerNorm-like behavior
        # GroupNorm default affine=True
        return nn.GroupNorm(num_groups, num_features, **kwargs)  # eps
    if norm_type_lower == "instance":
        # InstanceNorm3d default affine=False,
        # but often set to True in practice if learnable params are desired.
        # Let's assume affine=True to be consistent with others having learnable params.
        return nn.InstanceNorm3d(num_features, affine=kwargs.get("affine", True), **kwargs)
    if norm_type_lower == "none" or norm_type_lower == "":
        return nn.Identity()

    raise ValueError(f"Unknown normalization type: {norm_type}")
