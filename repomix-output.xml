# src/ssunet/modules/special_layers.py
"""Special convolution layers and custom components for SSUnet."""

import torch
import torch.nn.functional as F  # noqa: N812
from torch import nn


# Custom Activation Functions
class GatedReLUMix(nn.Module):
    """Mixes two parallel processing paths using ReLU and gating mechanism."""

    def __init__(self) -> None:
        super().__init__()

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        channels = x.shape[1]
        if channels % 2 != 0:
            raise ValueError(f"Input channels must be even for GatedReLUMix, but got {channels}")
        x1, x2 = torch.chunk(x, 2, dim=1)
        out1 = F.relu(x1)
        out2 = x1 * x2
        return torch.cat((out1, out2), dim=1)


class SinGatedMix(nn.Module):
    """Mixes a direct sinusoidal activation with sinusoidally gated second half."""

    def __init__(self) -> None:
        super().__init__()

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        channels = x.shape[1]
        if channels % 2 != 0:
            raise ValueError(f"Input channels must be even for SinGatedMix, but got {channels}")
        x1, x2 = torch.chunk(x, 2, dim=1)
        sin_gate_x1 = torch.sin(x1)
        out1 = sin_gate_x1
        out2 = sin_gate_x1 * x2
        return torch.cat((out1, out2), dim=1)


# Partial Convolution Layers (Example, assuming full definition exists if used)
class PartialConv3d(nn.Conv3d):
    def __init__(self, *args, multi_channel: bool = True, return_mask: bool = False, **kwargs):
        super().__init__(*args, **kwargs)
        # ... (full implementation) ...
        pass  # Placeholder


# Pixel Shuffle/Unshuffle Layers
class PixelShuffle3d(nn.Module):
    """3D version of pixel shuffle for efficient upsampling."""

    def __init__(self, scale: int = 2):
        super().__init__()
        if scale <= 0:
            raise ValueError("Scale must be positive.")
        self.scale = scale

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        B, C, D, H, W = x.shape
        s = self.scale
        if C % (s**3) != 0:
            raise ValueError(f"Input channels ({C}) must be divisible by scale^3 ({s**3}).")
        C_out = C // (s**3)
        D_out, H_out, W_out = D * s, H * s, W * s

        x = x.contiguous().view(B, C_out, s, s, s, D, H, W)
        x = x.permute(0, 1, 5, 2, 6, 3, 7, 4).contiguous()  # B, C_out, D,s,H,s,W,s
        return x.view(B, C_out, D_out, H_out, W_out)


class PixelUnshuffle3d(nn.Module):
    """3D version of pixel unshuffle for efficient downsampling."""

    def __init__(self, scale: int = 2):
        super().__init__()
        if scale <= 0:
            raise ValueError("Scale must be positive.")
        self.scale = scale

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        B, C, D, H, W = x.shape
        s = self.scale
        if not all(dim % s == 0 for dim in (D, H, W)):
            raise ValueError(f"Spatial dimensions ({D},{H},{W}) must be divisible by scale ({s}).")
        C_out = C * (s**3)
        D_out, H_out, W_out = D // s, H // s, W // s

        x = x.contiguous().view(B, C, D_out, s, H_out, s, W_out, s)
        x = x.permute(0, 1, 3, 5, 7, 2, 4, 6).contiguous()  # B, C, s,s,s, D_out,H_out,W_out
        return x.view(B, C_out, D_out, H_out, W_out)


class PixelShuffle2d(nn.Module):
    """2D pixel shuffle on BCZXY data (XY only)."""

    def __init__(self, scale: int = 2):
        super().__init__()
        if scale <= 0:
            raise ValueError("Scale must be positive.")
        self.scale = scale

    def forward(self, x: torch.Tensor) -> torch.Tensor:  # (B, C, Z, H, W)
        B, C, Z, H, W = x.shape
        s = self.scale
        if C % (s**2) != 0:
            raise ValueError(f"Input channels ({C}) must be divisible by scale^2 ({s**2}).")
        C_out = C // (s**2)
        H_out, W_out = H * s, W * s

        x = x.contiguous().view(B, C_out, s, s, Z, H, W)
        x = x.permute(0, 1, 4, 5, 2, 6, 3).contiguous()  # B, C_out, Z, H,s, W,s
        return x.view(B, C_out, Z, H_out, W_out)


class PixelUnshuffle2d(nn.Module):
    """2D pixel unshuffle on BCZXY data (XY only)."""

    def __init__(self, scale: int = 2):
        super().__init__()
        if scale <= 0:
            raise ValueError("Scale must be positive.")
        self.scale = scale

    def forward(self, x: torch.Tensor) -> torch.Tensor:  # (B, C, Z, H, W)
        B, C, Z, H, W = x.shape
        s = self.scale
        if not all(dim % s == 0 for dim in (H, W)):
            raise ValueError(f"H,W dimensions ({H},{W}) must be divisible by scale ({s}).")
        C_out = C * (s**2)
        H_out, W_out = H // s, W // s

        x = x.contiguous().view(B, C, Z, H_out, s, W_out, s)
        x = x.permute(0, 1, 4, 6, 2, 3, 5).contiguous()  # B, C, s,s, Z, H_out,W_out
        return x.view(B, C_out, Z, H_out, W_out)
