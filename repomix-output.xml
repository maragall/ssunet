"""U-Net building blocks for 3D medical image processing."""

from functools import partial

import torch
from torch import nn

from .layers import (
    ConvNeXtBlock3D,
    activation_function,
    conv111,
    conv333,
    merge,
    merge_conv,
    pool,
    upconv222,
)
from .normalization import LayerNorm3D, get_norm_layer

"""U-Net building blocks for 3D medical image processing."""


# Base class for all blocks
class BaseUnetBlock3D(nn.Module):
    """Base class for modern U-Net blocks with proven improvements."""

    def __init__(
        self,
        in_channels: int,
        out_channels: int,
        skip_out: bool = True,
        dropout_p: float = 0.0,
        down_mode: str = "maxpool",
        up_mode: str = "transpose",
        merge_mode: str = "concat",
        use_attention: bool = False,
        z_conv: bool = True,
        activation: str = "gelu",  # Added activation parameter
        **kwargs: dict,
    ) -> None:
        super().__init__()
        self.in_channels = in_channels
        self.out_channels = out_channels
        self.skip_out = skip_out
        self.dropout_p = dropout_p
        self.up_mode = up_mode
        self.merge_mode = merge_mode  # Stored for use in child classes
        self.use_attention = use_attention
        self.z_conv = z_conv
        self.activation_name = activation  # Store activation name
        self.kwargs = kwargs

        # Core components
        self.dropout = nn.Dropout3d(p=dropout_p) if dropout_p > 0 else nn.Identity()

        # Use the activation_function factory from layers.py
        self.activation = activation_function(activation, **kwargs.get("activation_kwargs", {}))

        # Setup operation functions to avoid lambda serialization issues
        self._setup_operations(down_mode, up_mode, self.merge_mode)

        self._build_layers()  # Define layers first
        self.apply(
            self._init_weights
        )  # Then initialize all weights including those in _build_layers

    def _setup_operations(self, down_mode: str, up_mode: str, merge_mode_arg: str):
        """Setup operation functions to avoid lambda serialization issues."""
        self.merge = partial(merge, merge_mode=merge_mode_arg)
        self.merge_conv = partial(merge_conv, z_conv=self.z_conv, mode=merge_mode_arg)
        self.down_sample = partial(pool, down_mode=down_mode, z_conv=self.z_conv, last=False)
        self.up_sample = upconv222(self.in_channels, self.out_channels, self.z_conv, up_mode)

    def _build_layers(self):
        """Define the specific layers for this block."""
        raise NotImplementedError

    def _init_weights(self, module):
        """Initialize weights using He initialization."""
        if isinstance(module, nn.Conv3d | nn.ConvTranspose3d):
            # Adjust initialization based on activation
            if self.activation_name.lower() in ["relu", "leaky"]:
                nn.init.kaiming_normal_(module.weight, mode="fan_out", nonlinearity="relu")
            elif self.activation_name.lower() in ["silu", "gelu"]:
                nn.init.kaiming_normal_(module.weight, mode="fan_out", nonlinearity="relu")
            else:
                nn.init.xavier_normal_(module.weight)

            if module.bias is not None:
                nn.init.constant_(module.bias, 0)
        elif isinstance(module, nn.Linear):
            if self.activation_name.lower() in ["relu", "leaky"]:
                nn.init.kaiming_normal_(module.weight, mode="fan_out", nonlinearity="relu")
            else:
                nn.init.xavier_normal_(module.weight)

            if module.bias is not None:
                nn.init.constant_(module.bias, 0)


# Encoder blocks
class EfficientDownBlock3D(BaseUnetBlock3D):
    """Efficient downsampling block with residual connection."""

    def _build_layers(self):
        self.residual = conv111(self.in_channels, self.out_channels)
        self.conv1 = conv333(self.in_channels, self.out_channels, z_conv=self.z_conv)
        self.norm1 = LayerNorm3D(self.out_channels)
        self.conv2 = conv333(self.out_channels, self.out_channels, z_conv=self.z_conv)
        self.norm2 = LayerNorm3D(self.out_channels)
        self.pool = self.down_sample(self.out_channels, self.out_channels)  # type: ignore

    def forward(self, x: torch.Tensor) -> tuple[torch.Tensor, torch.Tensor | None]:
        residual = self.residual(x)
        out = self.conv1(x)
        out = self.norm1(out)
        out = self.activation(out)
        out = self.conv2(out)
        out = self.norm2(out)
        out = self.activation(out)
        out = out + residual
        before_pool = self.dropout(out)
        pooled = self.pool(before_pool)
        return (pooled, before_pool) if self.skip_out else (pooled, None)


class ConvNeXtDownBlock3D(BaseUnetBlock3D):
    """State-of-the-art downsampling block using ConvNeXt design."""

    def _build_layers(self):
        num_blocks = self.kwargs.get("num_blocks", 2)
        expand_ratio = self.kwargs.get("expand_ratio", 4)
        kernel_size = self.kwargs.get("kernel_size", 7)

        self.proj = nn.Identity()
        if self.in_channels != self.out_channels:
            self.proj = nn.Conv3d(self.in_channels, self.out_channels, kernel_size=1)

        self.blocks = nn.ModuleList(
            [
                ConvNeXtBlock3D(
                    self.out_channels,
                    expand_ratio=expand_ratio,
                    kernel_size=kernel_size,
                    z_conv=self.z_conv,
                )
                for _ in range(num_blocks)
            ]
        )
        self.pool = self.down_sample(self.out_channels, self.out_channels)  # type: ignore

    def forward(self, x: torch.Tensor) -> tuple[torch.Tensor, torch.Tensor | None]:
        x = self.proj(x)
        for block_module in self.blocks:
            x = block_module(x)
        before_pool = self.dropout(x)
        pooled = self.pool(before_pool)
        return (pooled, before_pool) if self.skip_out else (pooled, None)


# NAFNet blocks
class SimpleGate3D(nn.Module):
    """3D Simple Gate mechanism from NAFNet."""

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        x1, x2 = x.chunk(2, dim=1)
        return x1 * x2


class NAFBlock3D(nn.Module):
    """3D NAFNet block with depthwise convolution and channel attention."""

    def __init__(
        self,
        channels: int,
        dw_expand: int = 2,
        ffn_expand: int = 2,
        dropout_p: float = 0.0,
        z_conv: bool = True,
    ):
        super().__init__()
        dw_channels = channels * dw_expand

        # Spatial mixing path
        self.conv1 = conv111(channels, dw_channels)

        # Depthwise convolution
        kernel = 3 if z_conv else (1, 3, 3)
        padding = 1 if z_conv else (0, 1, 1)
        self.conv2 = nn.Conv3d(
            dw_channels,
            dw_channels,
            kernel_size=kernel,
            stride=1,
            padding=padding,
            groups=dw_channels,
            bias=True,
        )

        # Channel attention
        self.sca = nn.Sequential(
            nn.AdaptiveAvgPool3d(1),
            nn.Conv3d(dw_channels // 2, dw_channels // 2, kernel_size=1, bias=True),
        )

        self.conv3 = conv111(dw_channels // 2, channels)

        # FFN path
        ffn_channels = channels * ffn_expand
        self.conv4 = conv111(channels, ffn_channels)
        self.conv5 = conv111(ffn_channels // 2, channels)

        # Gates - NAFNet always uses SimpleGate
        self.sg1 = SimpleGate3D()
        self.sg2 = SimpleGate3D()

        # Normalization
        self.norm1 = LayerNorm3D(channels)
        self.norm2 = LayerNorm3D(channels)

        # Dropout
        self.dropout1 = nn.Dropout3d(dropout_p) if dropout_p > 0 else nn.Identity()
        self.dropout2 = nn.Dropout3d(dropout_p) if dropout_p > 0 else nn.Identity()

        # Learnable scaling parameters
        self.beta = nn.Parameter(torch.zeros(1, channels, 1, 1, 1))
        self.gamma = nn.Parameter(torch.zeros(1, channels, 1, 1, 1))

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        identity = x

        # Spatial mixing branch
        out = self.norm1(x)
        out = self.conv1(out)
        out = self.conv2(out)
        out = self.sg1(out)  # SimpleGate splits channels

        # Channel attention
        sca_out = self.sca(out)
        out = out * sca_out
        out = self.conv3(out)
        out = self.dropout1(out)

        # First residual connection
        x = identity + out * self.beta

        # Channel mixing branch (FFN)
        identity = x
        out = self.norm2(x)
        out = self.conv4(out)
        out = self.sg2(out)
        out = self.conv5(out)
        out = self.dropout2(out)

        # Second residual connection
        return identity + out * self.gamma


class NAFDownBlock3D(BaseUnetBlock3D):
    """NAFNet-inspired downsampling block for 3D data."""

    def _build_layers(self):
        num_blocks = self.kwargs.get("num_blocks", 2)
        dw_expand = self.kwargs.get("dw_expand", 2)
        ffn_expand = self.kwargs.get("ffn_expand", 2)

        # Initial projection if needed
        self.proj = nn.Identity()
        if self.in_channels != self.out_channels:
            self.proj = conv111(self.in_channels, self.out_channels)

        # NAF blocks - note: NAFBlock3D doesn't use the activation parameter
        self.blocks = nn.ModuleList(
            [
                NAFBlock3D(
                    self.out_channels,
                    dw_expand=dw_expand,
                    ffn_expand=ffn_expand,
                    dropout_p=self.dropout_p,
                    z_conv=self.z_conv,
                )
                for _ in range(num_blocks)
            ]
        )

        # Downsampling
        self.pool = self.down_sample(self.out_channels, self.out_channels)

    def forward(self, x: torch.Tensor) -> tuple[torch.Tensor, torch.Tensor | None]:
        x = self.proj(x)

        for block in self.blocks:
            x = block(x)

        before_pool = x
        pooled = self.pool(before_pool)

        return (pooled, before_pool) if self.skip_out else (pooled, None)


class NAFUpBlock3D(BaseUnetBlock3D):
    """NAFNet-inspired upsampling block for 3D data."""

    def _build_layers(self):
        num_blocks = self.kwargs.get("num_blocks", 2)
        dw_expand = self.kwargs.get("dw_expand", 2)
        ffn_expand = self.kwargs.get("ffn_expand", 2)

        x_upsampled_channels = self.out_channels
        skip_channels = self.out_channels

        # Define projection layers based on merge mode
        if self.merge_mode == "concat":
            merged_channels_skip_present = x_upsampled_channels + skip_channels
            merged_channels_skip_absent = x_upsampled_channels
        else:  # add mode
            merged_channels_skip_present = self.out_channels
            merged_channels_skip_absent = self.out_channels

        # Projection layers
        self.proj_skip_present = (
            conv111(merged_channels_skip_present, self.out_channels)
            if merged_channels_skip_present != self.out_channels
            else nn.Identity()
        )

        if self.merge_mode == "concat":
            self.proj_skip_absent = (
                conv111(merged_channels_skip_absent, self.out_channels)
                if merged_channels_skip_absent != self.out_channels
                else nn.Identity()
            )

        # NAF blocks - note: NAFBlock3D doesn't use the activation parameter
        self.blocks = nn.ModuleList(
            [
                NAFBlock3D(
                    self.out_channels,
                    dw_expand=dw_expand,
                    ffn_expand=ffn_expand,
                    dropout_p=self.dropout_p,
                    z_conv=self.z_conv,
                )
                for _ in range(num_blocks)
            ]
        )

    def forward(self, x: torch.Tensor, skip: torch.Tensor | None = None) -> torch.Tensor:
        x_up = self.up_sample(x)

        if skip is not None:
            merged = self.merge(x_up, skip)
            x = self.proj_skip_present(merged)
        else:
            if self.merge_mode == "concat":
                x = self.proj_skip_absent(x_up)
            else:
                x = self.proj_skip_present(x_up)

        for block in self.blocks:
            x = block(x)

        return x


# Decoder blocks
class EfficientUpBlock3D(BaseUnetBlock3D):
    """Efficient upsampling block with skip connection fusion."""

    def _build_layers(self):
        x_upsampled_channels = self.out_channels
        skip_channels = self.out_channels  # Convention for skip connections

        # Define layers for when skip connection IS present
        if self.merge_mode == "concat":
            merged_channels_skip_present = x_upsampled_channels + skip_channels
        else:  # add mode
            merged_channels_skip_present = self.out_channels

        self.conv1_skip_present = conv333(
            merged_channels_skip_present, self.out_channels, z_conv=self.z_conv
        )
        self.residual_conv_skip_present = conv111(merged_channels_skip_present, self.out_channels)

        # Define specific conv1 for when skip is ABSENT and mode is "concat"
        if self.merge_mode == "concat":
            # Input is x_upsampled (self.out_channels)
            self.conv1_skip_absent_concat = conv333(
                self.out_channels, self.out_channels, z_conv=self.z_conv
            )
        # Note: If merge_mode is "add" and skip is absent, self.conv1_skip_present can be reused
        # as its input channel count (self.out_channels) matches x_upsampled.

        self.norm1 = LayerNorm3D(self.out_channels)
        self.conv2 = conv333(self.out_channels, self.out_channels, z_conv=self.z_conv)
        self.norm2 = LayerNorm3D(self.out_channels)

        # For the residual path when skip is ABSENT (input is x_upsampled with self.out_channels)
        self.residual_proj_skip_absent = nn.Identity()

    def forward(self, x: torch.Tensor, skip: torch.Tensor | None = None) -> torch.Tensor:
        x_upsampled = self.up_sample(x)  # Outputs self.out_channels

        current_residual: torch.Tensor
        main_path_after_conv1: torch.Tensor  # Renamed for clarity

        if skip is not None:
            # This merge function must be from your .layers import
            merged_x = self.merge(x_upsampled, skip)
            current_residual = self.residual_conv_skip_present(merged_x)
            main_path_after_conv1 = self.conv1_skip_present(merged_x)
        else:  # skip is None
            current_residual = self.residual_proj_skip_absent(x_upsampled)  # Processes x_upsampled
            if self.merge_mode == "concat":
                # merged_x would be x_upsampled (self.out_channels).
                # self.conv1_skip_present expects 2*out_channels for concat mode.
                # So, use self.conv1_skip_absent_concat which expects self.out_channels.
                main_path_after_conv1 = self.conv1_skip_absent_concat(x_upsampled)
            else:  # merge_mode == "add"
                # merged_x would be x_upsampled (self.out_channels).
                # self.conv1_skip_present expects self.out_channels for add mode. This is fine.
                main_path_after_conv1 = self.conv1_skip_present(x_upsampled)

        out = self.norm1(main_path_after_conv1)
        out = self.activation(out)
        out = self.conv2(out)
        out = self.norm2(out)
        out = self.activation(out)

        out = out + current_residual  # Add residual
        return self.dropout(out)


class ConvNeXtUpBlock3D(BaseUnetBlock3D):
    """Upsampling block using ConvNeXt design."""

    def _build_layers(self):
        x_upsampled_channels = self.out_channels
        skip_channels = self.out_channels  # Convention

        num_blocks = self.kwargs.get("num_blocks", 2)
        expand_ratio = self.kwargs.get("expand_ratio", 4)
        kernel_size = self.kwargs.get("kernel_size", 7)

        # Define projection layer for when skip IS present
        if self.merge_mode == "concat":
            merged_input_channels_skip_present = x_upsampled_channels + skip_channels
        else:  # add mode
            merged_input_channels_skip_present = self.out_channels

        if merged_input_channels_skip_present != self.out_channels:
            self.proj_skip_present = nn.Conv3d(
                merged_input_channels_skip_present, self.out_channels, kernel_size=1
            )
        else:
            self.proj_skip_present = nn.Identity()

        # Define projection for when skip is ABSENT and mode is "concat"
        if self.merge_mode == "concat":
            # Input is x_upsampled (self.out_channels). Output for ConvNeXt blocks must be self.out_channels.
            # An Identity layer is sufficient if channels already match and no other transformation is needed.
            self.proj_skip_absent_concat = nn.Identity()
        # Note: If merge_mode is "add" and skip is absent, self.proj_skip_present can be reused
        # as its input (self.out_channels) matches x_upsampled, and it outputs self.out_channels.

        self.blocks = nn.ModuleList(
            [
                ConvNeXtBlock3D(
                    self.out_channels,  # Blocks always operate on self.out_channels
                    expand_ratio=expand_ratio,
                    kernel_size=kernel_size,
                    z_conv=self.z_conv,
                )
                for _ in range(num_blocks)
            ]
        )

    def forward(self, x: torch.Tensor, skip: torch.Tensor | None = None) -> torch.Tensor:
        x_up = self.up_sample(x)  # Has self.out_channels

        projected_x: torch.Tensor  # This will be the input to self.blocks

        if skip is not None:
            # This merge function must be from your .layers import
            merged_tensor = self.merge(x_up, skip)
            # self.proj_skip_present handles the merged_tensor (potentially 2*out_channels or out_channels)
            # and projects it to self.out_channels.
            projected_x = self.proj_skip_present(merged_tensor)
        else:  # skip is None
            # Input to ConvNeXt blocks must be self.out_channels. x_up already has self.out_channels.
            if self.merge_mode == "concat":
                # self.proj_skip_present was configured for 2*out_channels input in concat mode.
                # Here, input is x_up (self.out_channels). Use self.proj_skip_absent_concat.
                projected_x = self.proj_skip_absent_concat(x_up)
            else:  # merge_mode == "add"
                # self.proj_skip_present was configured for self.out_channels input in add mode.
                # Input x_up (self.out_channels) is compatible.
                projected_x = self.proj_skip_present(x_up)

        # Pass the correctly projected tensor through the ConvNeXt blocks
        for block_module in self.blocks:  # Renamed to avoid conflict
            projected_x = block_module(projected_x)
        return self.dropout(projected_x)


# Legacy blocks (kept for backward compatibility only)
class DownConvTri3D(nn.Module):
    """Legacy triple convolution downsampling block."""

    def __init__(
        self,
        in_channels: int,
        out_channels: int,
        z_conv: bool = True,
        skip_out: bool = True,
        dropout_p: float = 0.0,
        group_norm: int = 0,
        down_mode: str = "maxpool",
        activation: str = "relu",
        **kwargs,
    ):
        super().__init__()

        if group_norm > 0 and out_channels % group_norm != 0:
            raise ValueError(
                f"out_channels ({out_channels}) must be divisible by group_norm ({group_norm})"
            )

        self.skip_out = skip_out
        self.z_conv = z_conv
        self.resconv = conv333(in_channels, out_channels, z_conv)
        self.conv2 = conv333(out_channels, out_channels, z_conv)
        self.conv3 = conv333(out_channels, out_channels, z_conv)
        self.pool = pool(out_channels, out_channels, down_mode, z_conv, kwargs.get("last", False))
        self.dropout = nn.Dropout3d(p=dropout_p) if dropout_p > 0 else nn.Identity()
        self.group_norm = (
            nn.GroupNorm(group_norm, out_channels) if group_norm > 0 else nn.Identity()
        )
        # Use activation_function factory
        self.activation = activation_function(activation, **kwargs.get("activation_kwargs", {}))
        self.apply(self._init_weights)

    def _init_weights(self, module):
        if isinstance(module, (nn.Conv3d, nn.ConvTranspose3d)):
            nn.init.kaiming_normal_(module.weight, mode="fan_out", nonlinearity="relu")
            if module.bias is not None:
                nn.init.constant_(module.bias, 0)

    def forward(self, x: torch.Tensor) -> tuple[torch.Tensor, torch.Tensor | None]:
        residual = self.group_norm(self.resconv(x))
        out = self.activation(self.group_norm(self.conv2(residual)))
        out = self.activation(self.group_norm(self.conv3(out) + residual))
        before_pool = self.dropout(out)
        output = self.pool(before_pool)
        return (output, before_pool) if self.skip_out else (output, None)


class UpConvTri3D(nn.Module):
    """Legacy triple convolution upsampling block."""

    def __init__(
        self,
        in_channels: int,
        out_channels: int,
        z_conv: bool = True,
        skip_out: bool = True,  # skip_out is not typically used by Up blocks, but kept for consistency
        dropout_p: float = 0.0,
        group_norm: int = 0,
        up_mode: str = "transpose",
        merge_mode: str = "concat",
        activation: str = "relu",
        **kwargs,
    ):
        super().__init__()

        if group_norm > 0 and out_channels % group_norm != 0:
            raise ValueError(
                f"out_channels ({out_channels}) must be divisible by group_norm ({group_norm})"
            )

        self.z_conv = z_conv
        self.up_sample = upconv222(in_channels, out_channels, z_conv, up_mode)
        self.merge = partial(merge, merge_mode=merge_mode)
        # merge_conv in UpConvTri3D assumes it gets 'out_channels' from skip and 'out_channels' from up_sample
        # and its internal conv handles the doubled channels if mode is concat.
        self.resconv = merge_conv(out_channels, out_channels, z_conv, merge_mode)
        self.conv2 = conv333(out_channels, out_channels, z_conv)
        self.conv3 = conv333(out_channels, out_channels, z_conv)
        self.dropout = nn.Dropout3d(p=dropout_p) if dropout_p > 0 else nn.Identity()
        self.group_norm = (
            nn.GroupNorm(group_norm, out_channels) if group_norm > 0 else nn.Identity()
        )
        # Use activation_function factory
        self.activation = activation_function(activation, **kwargs.get("activation_kwargs", {}))
        self.apply(self._init_weights)

    def _init_weights(self, module):
        if isinstance(module, (nn.Conv3d, nn.ConvTranspose3d)):
            nn.init.kaiming_normal_(module.weight, mode="fan_out", nonlinearity="relu")
            if module.bias is not None:
                nn.init.constant_(module.bias, 0)

    def forward(self, x: torch.Tensor, skip: torch.Tensor | None = None) -> torch.Tensor:
        x_up = self.up_sample(x)
        # The merge function here should be the one from .layers
        merged_output = self.merge(x_up, skip)

        # The legacy resconv is only applied if skip is present, effectively processing the merged data.
        # If skip is None, merged_output is x_up, and resconv is skipped.
        # This logic is different from the modern blocks and is preserved for legacy.
        if skip is not None:
            residual = self.group_norm(self.resconv(merged_output))
        else:
            residual = merged_output  # which is x_up if skip is None

        out = self.activation(self.group_norm(self.conv2(residual)))
        out = self.activation(self.group_norm(self.conv3(out) + residual))
        return self.dropout(out)


# Aliases and block mapping
DownBlock3D = EfficientDownBlock3D
UpBlock3D = EfficientUpBlock3D

BLOCK = {
    "default": (EfficientDownBlock3D, EfficientUpBlock3D),
    "efficient": (EfficientDownBlock3D, EfficientUpBlock3D),
    "convnext": (ConvNeXtDownBlock3D, ConvNeXtUpBlock3D),
    "nafnet": (NAFDownBlock3D, NAFUpBlock3D),  # Added NAFNet blocks
    "tri": (DownConvTri3D, UpConvTri3D),  # Legacy, kept for compatibility
    "dual": (DownConvTri3D, UpConvTri3D),  # Map dual to tri for backward compatibility
