# src/ssunet/modules/layers.py

import torch
from torch import nn
from typing import TypeAlias, ClassVar

from ..constants import LOGGER  # Ensure ..constants.LOGGER is correctly set up
from .normalization import get_norm_layer
from .special_layers import (
    GatedReLUMix,
    # PartialConv3d, # If used
    PixelShuffle2d,
    PixelShuffle3d,
    PixelUnshuffle2d,
    PixelUnshuffle3d,
    SinGatedMix,
)

KernelSize3D: TypeAlias = int | tuple[int, int, int]
Stride3D: TypeAlias = int | tuple[int, int, int]


# --- Refined Convolution Creation ---
def _calculate_padding(kernel_size: KernelSize3D, z_conv: bool) -> int | tuple[int, int, int]:
    actual_kernel_tuple: tuple[int, int, int]
    if isinstance(kernel_size, int):
        actual_kernel_tuple = (
            (kernel_size, kernel_size, kernel_size) if z_conv else (1, kernel_size, kernel_size)
        )
    else:
        actual_kernel_tuple = kernel_size
    if not all(k > 0 for k in actual_kernel_tuple):
        raise ValueError(f"Kernel dimensions must be positive, got {actual_kernel_tuple}")
    padding = tuple(k // 2 for k in actual_kernel_tuple)
    if len(padding) == 3 and actual_kernel_tuple[0] == 1 and not z_conv:
        return (0, padding[1], padding[2])
    if all(p == padding[0] for p in padding) and isinstance(kernel_size, int):
        return padding[0]
    return padding


def create_conv3d(
    in_channels: int,
    out_channels: int,
    kernel_size: KernelSize3D,
    z_conv: bool = True,
    stride: Stride3D = 1,
    is_depthwise: bool = False,
    bias: bool = True,  # Bias is now determined by caller context (e.g. build_conv_unit3d)
) -> nn.Conv3d:
    actual_kernel: KernelSize3D = kernel_size
    if isinstance(kernel_size, int) and not z_conv and kernel_size > 1:
        actual_kernel = (1, kernel_size, kernel_size)

    padding = _calculate_padding(actual_kernel, z_conv)
    groups = in_channels if is_depthwise else 1
    _out_channels = out_channels
    if is_depthwise and out_channels != in_channels:
        LOGGER.debug(  # Changed to debug as it's a corrective action
            f"Depthwise convolution with in_channels ({in_channels}) "
            f"!= out_channels ({out_channels}). Forcing out_channels=in_channels."
        )
        _out_channels = in_channels

    return nn.Conv3d(
        in_channels,
        _out_channels,
        actual_kernel,
        stride=stride,
        padding=padding,
        groups=groups,
        bias=bias,
    )


# Basic conv helpers now default bias=True. Caller (like build_conv_unit3d) decides final bias.
def conv111(in_channels: int, out_channels: int, bias: bool = True) -> nn.Conv3d:
    return create_conv3d(in_channels, out_channels, 1, z_conv=True, bias=bias)


def conv333(
    in_channels: int, out_channels: int, z_conv: bool = True, bias: bool = True
) -> nn.Conv3d:
    return create_conv3d(in_channels, out_channels, 3, z_conv=z_conv, bias=bias)


def depthwise_conv333(
    channels: int, z_conv: bool = True, bias: bool = True
) -> nn.Conv3d:  # Defaulting bias to True here
    return create_conv3d(channels, channels, 3, z_conv=z_conv, is_depthwise=True, bias=bias)


def conv777(
    in_channels: int, out_channels: int, z_conv: bool = True, bias: bool = True
) -> nn.Conv3d:
    return create_conv3d(in_channels, out_channels, 7, z_conv=z_conv, bias=bias)


# --- Versatile Convolution Unit Builder ---
def build_conv_unit3d(
    in_channels: int,
    out_channels: int,
    kernel_size: int,
    z_conv: bool,
    activation_fn: nn.Module,
    norm_type: str = "layer",
    norm_params: dict | None = None,  # e.g. {"num_groups": ...}
    use_depthwise_separable: bool = False,
    stride: Stride3D = 1,
) -> nn.Sequential:
    if norm_params is None:
        norm_params = {}

    layers_unit = []

    # Bias is False if a real norm layer (not Identity) follows, otherwise True
    conv_bias_if_norm_follows = False
    conv_bias_if_no_norm = True

    if use_depthwise_separable and kernel_size > 1:
        # Depthwise part
        # Bias for DW conv: False if its own norm follows, else True
        dw_actual_bias = conv_bias_if_norm_follows if norm_type != "none" else conv_bias_if_no_norm
        layers_unit.append(
            create_conv3d(
                in_channels,
                in_channels,
                kernel_size,
                z_conv,
                stride=stride,
                is_depthwise=True,
                bias=dw_actual_bias,
            )
        )
        if norm_type != "none":
            layers_unit.append(get_norm_layer(norm_type, in_channels, **norm_params))
        layers_unit.append(activation_fn)

        # Pointwise part (1x1x1 conv)
        # Bias for PW conv: False if final norm follows, else True
        pw_actual_bias = conv_bias_if_norm_follows if norm_type != "none" else conv_bias_if_no_norm
        layers_unit.append(
            create_conv3d(
                in_channels,
                out_channels,
                1,
                z_conv=True,
                stride=1,
                is_depthwise=False,
                bias=pw_actual_bias,
            )
        )
        current_c_for_final_norm_act = out_channels
    else:  # Standard convolution
        std_actual_bias = conv_bias_if_norm_follows if norm_type != "none" else conv_bias_if_no_norm
        layers_unit.append(
            create_conv3d(
                in_channels,
                out_channels,
                kernel_size,
                z_conv,
                stride=stride,
                is_depthwise=False,
                bias=std_actual_bias,
            )
        )
        current_c_for_final_norm_act = out_channels

    if norm_type != "none":
        layers_unit.append(get_norm_layer(norm_type, current_c_for_final_norm_act, **norm_params))
    layers_unit.append(activation_fn)

    return nn.Sequential(*layers_unit)


# --- Activation Function Factory ---
def activation_function(activation_name: str, activation_params: dict | None = None) -> nn.Module:
    if activation_params is None:
        activation_params = {}
    name_lower = activation_name.lower()
    if name_lower == "relu":
        return nn.ReLU(inplace=True)
    if name_lower == "leaky":
        return nn.LeakyReLU(inplace=True, **activation_params)
    if name_lower == "silu":
        return nn.SiLU(inplace=True)
    if name_lower == "gelu":
        return nn.GELU(**activation_params)
    if name_lower == "gated_relu_mix":
        return GatedReLUMix()
    if name_lower == "sin_gated_mix":
        return SinGatedMix()
    if name_lower == "none":
        return nn.Identity()
    LOGGER.warning(f"Unknown activation: {activation_name}. Using ReLU.")
    return nn.ReLU(inplace=True)


# --- Pooling and Upsampling (adapted) ---
def pool(
    in_channels: int,
    out_channels: int,
    down_mode: str,
    z_conv: bool,
    is_last_stage: bool = False,
) -> nn.Module:  # Removed default_conv_bias, bias decided internally
    if is_last_stage:
        return nn.Identity()
    kernel_size_pool: KernelSize3D = 2 if z_conv else (1, 2, 2)
    stride_pool: Stride3D = 2 if z_conv else (1, 2, 2)

    if down_mode == "maxpool":
        return nn.MaxPool3d(kernel_size_pool, stride=stride_pool)
    if down_mode == "avgpool":
        return nn.AvgPool3d(kernel_size_pool, stride=stride_pool)
    if down_mode == "conv":
        # Strided conv usually doesn't have norm right after it in this context (it *is* the downsampling)
        return create_conv3d(
            in_channels,
            out_channels,
            kernel_size=kernel_size_pool,
            z_conv=z_conv,
            stride=stride_pool,
            bias=True,
        )  # Default True bias
    if down_mode == "unshuffle":
        unshuffle_module: nn.Module
        expected_after_unshuffle: int
        if z_conv:
            unshuffle_module = PixelUnshuffle3d(2)
            expected_after_unshuffle = in_channels * 8
        else:
            unshuffle_module = PixelUnshuffle2d(2)
            expected_after_unshuffle = in_channels * 4
        if out_channels == expected_after_unshuffle:
            return unshuffle_module
        return nn.Sequential(
            unshuffle_module,
            conv111(expected_after_unshuffle, out_channels, bias=True),  # 1x1, default True bias
        )
    LOGGER.warning(f"Unknown down_mode: {down_mode}. Using maxpool.")
    return nn.MaxPool3d(kernel_size_pool, stride=stride_pool)


def upconv222(
    in_channels: int,
    out_channels: int,
    z_conv: bool,
    up_mode: str = "transpose",
) -> nn.Module:  # Removed default_conv_bias
    kernel_t: KernelSize3D = 2 if z_conv else (1, 2, 2)
    stride_t: Stride3D = 2 if z_conv else (1, 2, 2)
    scale_factor_tuple: tuple[int, int, int] | tuple[float, float, float] = (
        (2.0, 2.0, 2.0) if z_conv else (1.0, 2.0, 2.0)
    )

    if up_mode == "transpose":
        return nn.ConvTranspose3d(
            in_channels, out_channels, kernel_t, stride=stride_t, bias=True
        )  # Default True
    if up_mode == "pixelshuffle":
        shuffle_module: nn.Module
        div_factor = 8 if z_conv else 4
        if in_channels % div_factor == 0:
            shuffled_ch = in_channels // div_factor
            shuffle_module = PixelShuffle3d(2) if z_conv else PixelShuffle2d(2)
            if shuffled_ch == out_channels:
                return shuffle_module
            return nn.Sequential(
                shuffle_module, conv111(shuffled_ch, out_channels, bias=True)
            )  # Default True
        LOGGER.warning(f"PixelShuffle{'3D' if z_conv else '2D'} fail. Fallback TransposeConv.")
        return nn.ConvTranspose3d(
            in_channels, out_channels, kernel_t, stride=stride_t, bias=True
        )  # Default True

    upsample_mode = up_mode if up_mode in ["trilinear", "nearest", "bilinear"] else "trilinear"
    align_corners_val = None
    if (
        upsample_mode == "trilinear" or upsample_mode == "bilinear" or upsample_mode == "linear"
    ):  # PyTorch specific for linear modes
        align_corners_val = False
    return nn.Sequential(
        nn.Upsample(
            scale_factor=scale_factor_tuple, mode=upsample_mode, align_corners=align_corners_val
        ),
        conv333(
            in_channels, out_channels, z_conv, bias=True
        ),  # Conv after upsample, default True bias
    )


# --- Merge operations ---
def merge(
    input_a: torch.Tensor, input_b: torch.Tensor | None, merge_mode: str = "concat"
) -> torch.Tensor:
    if input_b is None:
        return input_a
    if merge_mode == "concat":
        return torch.cat((input_a, input_b), dim=1)
    if merge_mode == "add":
        if input_a.shape != input_b.shape:
            LOGGER.warning(
                f"Add merge: shapes mismatch {input_a.shape} vs {input_b.shape}. Attempting 1x1 on skip."
            )
            if input_a.shape[1] != input_b.shape[1]:
                proj = conv111(input_b.shape[1], input_a.shape[1], bias=True).to(
                    input_b.device, input_b.dtype
                )
                input_b = proj(input_b)
            # Add more checks for spatial dimensions if necessary, potentially padding/cropping
        return input_a + input_b
    LOGGER.warning(f"Unknown merge_mode: {merge_mode}. Using concat.")
    return torch.cat((input_a, input_b), dim=1)


# --- Specialized Blocks ---
class ConvNeXtBlock3D(nn.Module):
    DEFAULT_BLOCK_CONFIG: dict = {
        "expand_ratio": 4,
        "kernel_size": 7,
        "layer_scale_init": 1e-6,
        "norm_type": "layer",
        "activation_name": "gelu",
    }

    def __init__(self, channels: int, z_conv: bool = True, block_config: dict | None = None):
        super().__init__()
        cfg = {**self.DEFAULT_BLOCK_CONFIG, **(block_config or {})}
        norm_params_internal = {}  # If norm_params were needed for get_norm_layer

        # DW Conv is followed by Norm, so bias=False
        self.dwconv = create_conv3d(
            channels, channels, cfg["kernel_size"], z_conv, is_depthwise=True, bias=False
        )
        self.norm = get_norm_layer(cfg["norm_type"], channels, **norm_params_internal)

        hidden_dim = channels * cfg["expand_ratio"]
        # Linear layers are not typically followed by spatial norm, so bias=True
        self.pwconv1 = nn.Linear(channels, hidden_dim, bias=True)
        self.act = activation_function(cfg["activation_name"], None)
        self.pwconv2 = nn.Linear(hidden_dim, channels, bias=True)

        if cfg["layer_scale_init"] > 0:
            self.layer_scale = nn.Parameter(
                cfg["layer_scale_init"] * torch.ones((channels, 1, 1, 1)), requires_grad=True
            )
        else:
            self.layer_scale = nn.Identity()

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        input_tensor = x
        x = self.dwconv(x)
        x = self.norm(x)
        x = x.permute(0, 2, 3, 4, 1)
        x = self.pwconv1(x)
        x = self.act(x)
        x = self.pwconv2(x)
        x = x.permute(0, 4, 1, 2, 3)
        return (
            input_tensor + self.layer_scale(x)
            if isinstance(self.layer_scale, nn.Parameter)
            else input_tensor + x
        )


class SimpleGate3D(nn.Module):
    def forward(self, x: torch.Tensor) -> torch.Tensor:
        x1, x2 = x.chunk(2, dim=1)
        return x1 * x2


class NAFBlock3D(nn.Module):
    DEFAULT_BLOCK_CONFIG: dict | Cl = {
        "dw_expand": 2,
        "ffn_expand": 2,
        "dropout_p": 0.0,
        "norm_type": "layer",  # NAFNet uses LayerNorm
    }

    def __init__(self, channels: int, z_conv: bool = True, block_config: dict | None = None):
        super().__init__()
        cfg = {**self.DEFAULT_BLOCK_CONFIG, **(block_config or {})}
        norm_params_internal = {}

        dw_channels = channels * cfg["dw_expand"]
        ffn_channels = channels * cfg["ffn_expand"]

        # Convs in NAFNet are complex; some are followed by norm, some not directly part of a unit.
        # NAFNet's original paper implies biases are generally true for their convs.
        # For simplicity here, let's assume True unless explicitly a conv-norm unit.
        # This block doesn't use build_conv_unit3d, so manual bias decisions.
        self.conv1 = conv111(
            channels, dw_channels, bias=True
        )  # Followed by norm in forward, but after xform
        kernel_dw: KernelSize3D = 3 if z_conv else (1, 3, 3)
        padding_dw = _calculate_padding(kernel_dw, z_conv)
        self.conv2 = nn.Conv3d(
            dw_channels, dw_channels, kernel_dw, 1, padding_dw, groups=dw_channels, bias=True
        )  # DW

        self.sca = nn.Sequential(
            nn.AdaptiveAvgPool3d(1), conv111(dw_channels // 2, dw_channels // 2, bias=True)
        )
        self.conv3 = conv111(dw_channels // 2, channels, bias=True)
        self.conv4 = conv111(channels, ffn_channels, bias=True)
        self.conv5 = conv111(ffn_channels // 2, channels, bias=True)

        self.sg1 = SimpleGate3D()
        self.sg2 = SimpleGate3D()
        self.norm1 = get_norm_layer(cfg["norm_type"], channels, **norm_params_internal)
        self.norm2 = get_norm_layer(cfg["norm_type"], channels, **norm_params_internal)
        self.dropout1 = nn.Dropout3d(cfg["dropout_p"]) if cfg["dropout_p"] > 0 else nn.Identity()
        self.dropout2 = nn.Dropout3d(cfg["dropout_p"]) if cfg["dropout_p"] > 0 else nn.Identity()
        self.beta = nn.Parameter(torch.zeros(1, channels, 1, 1, 1))
        self.gamma = nn.Parameter(torch.zeros(1, channels, 1, 1, 1))

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        identity = x
        out = self.norm1(x)
        out = self.conv1(out)
        out = self.conv2(out)
        out = self.sg1(out)
        out = out * self.sca(out)
        out = self.conv3(out)
        out = self.dropout1(out)
        x = identity + out * self.beta
        identity = x
        out = self.norm2(x)
        out = self.conv4(out)
        out = self.sg2(out)
        out = self.conv5(out)
        out = self.dropout2(out)
        return identity + out * self.gamma
